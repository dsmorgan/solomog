# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
#
# Solo enterprise license keys.
#
# If all your products use the same key, set SOLO_LICENSE_KEY and leave the
# per-product keys blank. If different products need different keys, set the
# per-product keys — each one takes precedence over SOLO_LICENSE_KEY for that
# product. This lets you map a specific license to a specific application.

# Fallback key used by any product that has no product-specific key set.
SOLO_LICENSE_KEY=

# Per-product overrides (optional — leave blank to fall back to SOLO_LICENSE_KEY).
# NOTE: the ="" (not bare =) matters — see the dotenv gotcha below.
SOLO_ISTIO_LICENSE_KEY=""      # Solo managed Istio via Gloo Operator
GLOO_MESH_LICENSE_KEY=""       # Gloo Mesh Enterprise mgmt plane (optional product)
KGATEWAY_LICENSE_KEY=""        # enterprise kgateway (kgateway 2.2.x)
GLOO_GATEWAY_LICENSE_KEY=""    # Gloo Gateway (gloo-ee 1.21.x) — separate product
AGENTGATEWAY_LICENSE_KEY=""    # enterprise agentgateway (2.3.x)

# ─── Output / cosmetics ──────────────────────────────────────────────────────
# Mute the 🗿 mog banter (the intro/outro quips the `solomog` wrapper prints around a run).
# The wrapper reads this itself (it doesn't source .env like `task` does). Precedence:
# env prefix / inline var win over .env — all three forms work:
#   SOLOMOG_SERIOUS=1 solomog …    |    solomog … SOLOMOG_SERIOUS=1    |    this line in .env
# Only affirmatives (1/true/yes/on) mute; "" (or false/0) keeps the banter on.
SOLOMOG_SERIOUS=""             # 1/true/yes/on = quiet output; "" = 🗿 banter on

# ─── Upstream credentials for AI/MCP backends ────────────────────────────────
# Secrets a bundle materializes into the cluster (see bundles/ + the .sh hook
# example). Keep the VALUE here in .env (gitignored); the bundle script only
# references the env var, so the script itself carries no secret and is safe to
# commit. Auto-sourced by Taskfile (dotenv) and inherited by bundle scripts.
CLAUDE_API_KEY=""             # Anthropic API key for an agentgateway LLM backend
OPENAI_API_KEY=""             # OpenAI API key (if pointing at the real provider)

# GCP / Vertex AI. PROJECT_ID and REGION configure the vertexai backend (projectId/
# region). GCP_ACCESS_TOKEN is a short-lived (~1h) OAuth token from gcloud — do NOT
# paste one by hand; run `solomog gcp:refresh` to (re)fetch it into .env, then re-run
# your bundle to apply it. It's a general GCP identity token, not Vertex-specific.
GCP_PROJECT_ID=""             # e.g. my-gcp-project
GCP_REGION=""                 # e.g. us-central1
GCP_ACCESS_TOKEN=""           # managed by `solomog gcp:refresh` (leave blank initially)

# AWS / Bedrock. The three AWS_* values are SHORT-LIVED SSO credentials — do NOT paste them
# by hand; run `solomog aws:refresh` to (re)fetch them into .env, then re-run your bundle.
# AWS_PROFILE selects which configured SSO profile aws:refresh exports (set it once after
# `aws configure sso`). AWS_SSO_SESSION names the SSO session for the login fallback (SOlo).
AWS_PROFILE=""                # e.g. solo-sso  (the profile `aws configure sso` created)
AWS_SSO_SESSION=""            # SSO session name (default: SOlo) — only used for sso-login
AWS_ACCESS_KEY_ID=""          # managed by `solomog aws:refresh` (leave blank initially)
AWS_SECRET_ACCESS_KEY=""      # managed by `solomog aws:refresh` (leave blank initially)
AWS_SESSION_TOKEN=""          # managed by `solomog aws:refresh` (leave blank initially)

# AWS Bedrock AgentCore runtime ARN — the Phase 0 MCP server (see
# bundles/private/citizens-260715/phase0-agentcore-mcp/). Consumed by the
# citizens-agentcore-rbac bundle's aws.agentCore backend + proxy-creds hooks. Get it from
# `agentcore deploy --json` / `agentcore status --json`. NOT a secret, but carries the account id.
AGENTCORE_RUNTIME_ARN=""      # e.g. arn:aws:bedrock-agentcore:us-east-1:170015905430:runtime/treasurymcp-xxxx

# ─── OBO token exchange (enterprise agentgateway STS) ────────────────────────
# TOKEN_EXCHANGE itself is CLI-ONLY — deliberately NOT settable here. It's a global,
# repo-wide dotenv value, not per-cluster, so persisting it would silently try to enable
# the STS on the NEXT agentgateway install on ANY cluster (even an unrelated one without
# Keycloak), crash-looping the controller. Pass it explicitly on the command that needs it:
#   solomog agentgateway CLUSTER=<cluster> TOKEN_EXCHANGE=true
# The two settings below ARE safe to persist — they're inert unless TOKEN_EXCHANGE=true is
# also passed on that same command.
# JWKS_URL is the IdP whose user tokens the STS validates (default: the in-cluster Keycloak
# from the OBO scenario). API_VALIDATOR=k8s suits the basic curl-driven OBO flow; set it to
# `remote` for the Solo UI's elicitation API. When remote, the apiValidator validates the UI's
# calls into the STS elicitation API. Per Solo's elicitation docs this is the SAME IdP JWKS as
# the subject validator (the UI, once wired to the IdP, signs its calls with IdP tokens) — so it
# DEFAULTS to TOKEN_EXCHANGE_JWKS_URL. Only set TOKEN_EXCHANGE_API_VALIDATOR_URL to override (e.g.
# the legacy autoauth keys http://solo-enterprise-ui...:5556/keys while the UI is still in dev mode).
TOKEN_EXCHANGE_JWKS_URL=""            # default: http://keycloak.keycloak.svc.cluster.local:8080/realms/obo-realm/protocol/openid-connect/certs
TOKEN_EXCHANGE_API_VALIDATOR=""       # k8s (default) | remote — use remote for Solo UI elicitation
# Elicitation (browser-consent OAuth to a SaaS, e.g. Snowflake). Both inert unless TOKEN_EXCHANGE=true.
# ELICITATION_SECRET is the GLOBAL fallback OAuth-provider secret the STS requires for elicitation
# (chart: tokenExchange.elicitation.secretName) — point it at the bundle's provider secret. CALLBACK_URL
# is the UI URL the browser returns to after consent; must match the secret's redirect_uri and the
# SaaS OAuth app's registered redirect.
TOKEN_EXCHANGE_ELICITATION_SECRET=""  # e.g. snowflake-elicitation (a Secret in agentgateway-system)
# CALLBACK_URL is CLUSTER-SPECIFIC. Leave BLANK and it derives from CLUSTER at install time:
#   https://ui.agw.<CLUSTER>.test/age/elicitations  (like OAUTH_ISSUER_HOST). Only set it to
# override for a non-default gateway/host — a value pinned here does NOT track the cluster, so
# installing on a different cluster would bake the wrong host into the control plane.
TOKEN_EXCHANGE_CALLBACK_URL=""

# ─── Okta (bundles/agw-okta-mcp — edge JWT validation) ───────────────────────
# Your Okta developer org + an "API Services" (machine-to-machine) app. OKTA_DOMAIN is the
# only value the applied config needs (the gateway just validates Okta's PUBLIC JWKS); the
# CLIENT_ID/SECRET/SCOPE are used ONLY by the bundle's tests to fetch a client-credentials
# token. The bundle assumes Okta's custom "default" authorization server (/oauth2/default).
# OKTA_SCOPE must be a scope your app is granted on that AS (create one, e.g. mcp.access).
OKTA_DOMAIN=""                        # org host, NO scheme (e.g. dev-1234567.okta.com)
OKTA_AUDIENCE=""                      # default: api://default (the default AS's audience)
OKTA_AUTH_SERVER_ID=""                # default: default (the custom "default" AS; used to build the eager-auth issuer URLs)
OKTA_CLIENT_ID=""                     # API Services app client id (tests only; ALSO the eager-auth pre-registered client — see below)
OKTA_CLIENT_SECRET=""                 # API Services app client secret (tests only; ALSO the eager-auth client secret)
OKTA_SCOPE=""                         # scope granted to the app on /oauth2/default (tests only)
# --- OBO / identity-propagation (Auth Code + PKCE user login) ---------------------------
# A SECOND Okta app: the user-facing OIDC client (Native = public/PKCE, or Web = confidential).
# Used by bundles/agw-okta-mcp/helpers/okta-pkce-login.sh to mint a real USER token (human sub).
OKTA_USER_CLIENT_ID=""                # the Native/Web OIDC app client id
OKTA_USER_CLIENT_SECRET=""            # set ONLY for a confidential Web app; leave blank for Native/public
OKTA_REDIRECT_URI=""                  # default http://localhost:8888/callback (must be registered on the app)
OKTA_USER_SCOPES=""                   # default "openid profile email mcp.access"

# ─── Okta device-authorization-grant app (bundles/agw-okta-bedrock-llm) ─────────────────
# A THIRD Okta app ("App E" in the bundle's OKTA-SETUP.md): a public Native app with the
# Device Authorization grant enabled, used by the bundle's CLI token helper (no browser
# redirect listener needed — distinct from OKTA_USER_CLIENT_ID's PKCE app above). Reuses
# OKTA_DOMAIN/OKTA_AUDIENCE from the Okta block above (same org, same default AS). Also
# needs the bundle's `groups` claim on that AS — see OKTA-SETUP.md step 2 (not an env var;
# it's Okta-side config the gateway's CEL authorization rules read as `jwt.groups`).
OKTA_DEVICE_CLIENT_ID=""              # App E — Native app client id (Device Authorization grant, no secret)
OKTA_DEVICE_SCOPES=""                  # default "openid profile offline_access" (matches OKTA-SETUP.md step 4's access-policy scopes)

# ─── Solo UI OIDC (management chart — wire the UI to the SAME IdP as the MCP route) ──────
# Needed for browser-consent ELICITATION (e.g. Snowflake): the elicited SaaS token is keyed by
# the user's `sub`, so the UI must log the user in as the SAME identity as the MCP-request JWT.
# Otherwise the UI runs in dev "autoauth" mode and the token lands under the wrong identity.
# Inert unless SOLO_UI_OIDC_ISSUER is set (then the agentgateway-ui addon renders the OIDC block
# and the UI leaves autoauth mode). Needs TWO Okta apps (App C = confidential Web, App D = SPA) —
# see bundles/agw-okta-mcp/OKTA-SETUP.md. Only ISSUER + the two client IDs shape config; the
# backend secret is injected inline (never committed). Also set TOKEN_EXCHANGE_API_VALIDATOR=remote
# (its URL then defaults to TOKEN_EXCHANGE_JWKS_URL — the same Okta JWKS).
SOLO_UI_OIDC_ISSUER=""                # e.g. https://integrator-5185242.okta.com/oauth2/default (matches the MCP-route JWT issuer)
SOLO_UI_OIDC_BACKEND_CLIENT_ID=""     # App C — confidential Web app client id
SOLO_UI_OIDC_BACKEND_CLIENT_SECRET="" # App C client secret (never committed)
SOLO_UI_OIDC_FRONTEND_CLIENT_ID=""    # App D — public SPA/PKCE app client id
SOLO_UI_OIDC_ADDITIONAL_SCOPES=""     # default ["profile","email"]  (add "groups" for group→role mapping)
SOLO_UI_OIDC_ROLE_MAPPER=""           # default ["global.Admin"] (PoV: all users admin); or a CEL claims.Groups mapper

# ─── Snowflake (bundles/agw-okta-mcp — elicitation OAuth backend) ─────────────
# From your Snowflake account + a custom OAuth security integration (see the bundle's
# SNOWFLAKE-SETUP runbook). The gateway does per-user browser OAuth consent (elicitation)
# against these and replays the resulting Snowflake token to the Snowflake MCP endpoint.
SNOWFLAKE_ACCOUNT_URL=""              # org URL, e.g. https://dimqfms-qy56216.snowflakecomputing.com
SNOWFLAKE_OAUTH_CLIENT_ID=""          # from SYSTEM$SHOW_OAUTH_CLIENT_SECRETS('AGW_MCP_OAUTH')
SNOWFLAKE_OAUTH_CLIENT_SECRET=""      # ditto (OAUTH_CLIENT_SECRET)
SNOWFLAKE_OAUTH_SCOPES=""             # default "session:role:AGW_ANALYST refresh_token" — Snowflake OAuth CUSTOM needs session:role:<ROLE>, NOT session:role-any (that's External OAuth)
SNOWFLAKE_MCP_DATABASE=""             # managed MCP server location — default: AGW_DEMO
SNOWFLAKE_MCP_SCHEMA=""               # default: PUBLIC
SNOWFLAKE_MCP_SERVER=""               # default: SNOWFLAKE_MCP

# ─── Eager-auth OAuth issuer (bundles/agw-atlassian-mcp) ─────────────────────
# The gateway becomes the OAuth Authorization Server MCP clients see (@ /oauth-issuer), doing
# "fake DCR" (returns a pre-registered Okta client) and brokering the auth-code flow to Okta.
# Enabled by a CLI-only flag on the install (NOT stored here, like TOKEN_EXCHANGE — enabling it
# on a cluster without the STS/config crash-loops the controller):
#     solomog agentgateway CLUSTER=<c> TOKEN_EXCHANGE=true OAUTH_ISSUER=true
# The eager-auth client must be a CONFIDENTIAL **Authorization Code** app with BOTH redirect URIs:
#     https://agw.<cluster>.test/oauth-issuer/callback/downstream
#     https://agw.<cluster>.test/oauth-issuer/callback/upstream
# This is NOT the API-Services (machine-to-machine) app OKTA_CLIENT_ID points at above — that grant
# can't do the browser flow. Simplest: create ONE dedicated Okta Web app (OIDC → Web Application →
# Authorization Code) with those two redirect URIs, and set it here. (Or reuse an existing confidential
# app, e.g. the Solo UI backend SOLO_UI_OIDC_BACKEND_*, by adding the two URIs to it.) Leave blank to
# fall back to OKTA_CLIENT_ID/SECRET (only correct if that IS a confidential Auth-Code app).
OAUTH_ISSUER_CLIENT_ID=""             # confidential Auth-Code app client id (the eager-auth downstream client)
OAUTH_ISSUER_CLIENT_SECRET=""         # its client secret (never committed)
# TOKEN_EXCHANGE_JWKS_URL must point at the Okta JWKS (https://<domain>/oauth2/<as-id>/v1/keys) for
# the STS subject/api validators. OAUTH_ISSUER_HOST defaults to agw.<cluster>.test.

# ─── Atlassian (bundles/agw-atlassian-mcp — Phase 2 target; per-user Jira/Confluence elicitation) ──
# Atlassian Jira/Confluence via mcp.atlassian.com. Atlassian's remote MCP uses Dynamic Client
# Registration, so there are NO client id/secret to set — the gateway registers itself dynamically
# (this is why it needs the eager-auth issuer above). All three below are OPTIONAL overrides. Needs
# a free Atlassian Cloud site (Jira/Confluence) to consent against. (Phase 1 of the bundle proves
# the eager-auth issuer against an in-cluster test MCP server and needs none of these.)
ATLASSIAN_BASE_URL=""                 # default https://mcp.atlassian.com (OAuth-discovery base)
ATLASSIAN_MCP_PATH=""                 # default /v1/mcp (StreamableHTTP); try /v1/mcp/authv2 if it 404s
ATLASSIAN_SCOPES=""                   # default "read:jira-work read:confluence-content.summary offline_access"
