# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
#
# Solo enterprise license keys.
#
# If all your products use the same key, set SOLO_LICENSE_KEY and leave the
# per-product keys blank. If different products need different keys, set the
# per-product keys — each one takes precedence over SOLO_LICENSE_KEY for that
# product. This lets you map a specific license to a specific application.

# Fallback key used by any product that has no product-specific key set.
SOLO_LICENSE_KEY=

# Per-product overrides (optional — leave blank to fall back to SOLO_LICENSE_KEY).
# NOTE: the ="" (not bare =) matters — see the dotenv gotcha below.
SOLO_ISTIO_LICENSE_KEY=""      # Solo managed Istio via Gloo Operator
GLOO_MESH_LICENSE_KEY=""       # Gloo Mesh Enterprise mgmt plane (optional product)
KGATEWAY_LICENSE_KEY=""        # enterprise kgateway (kgateway 2.2.x)
GLOO_GATEWAY_LICENSE_KEY=""    # Gloo Gateway (gloo-ee 1.21.x) — separate product
AGENTGATEWAY_LICENSE_KEY=""    # enterprise agentgateway (2.3.x)

# ─── Upstream credentials for AI/MCP backends ────────────────────────────────
# Secrets a bundle materializes into the cluster (see bundles/ + the .sh hook
# example). Keep the VALUE here in .env (gitignored); the bundle script only
# references the env var, so the script itself carries no secret and is safe to
# commit. Auto-sourced by Taskfile (dotenv) and inherited by bundle scripts.
CLAUDE_API_KEY=""             # Anthropic API key for an agentgateway LLM backend
OPENAI_API_KEY=""             # OpenAI API key (if pointing at the real provider)

# GCP / Vertex AI. PROJECT_ID and REGION configure the vertexai backend (projectId/
# region). GCP_ACCESS_TOKEN is a short-lived (~1h) OAuth token from gcloud — do NOT
# paste one by hand; run `solomog gcp:refresh` to (re)fetch it into .env, then re-run
# your bundle to apply it. It's a general GCP identity token, not Vertex-specific.
GCP_PROJECT_ID=""             # e.g. my-gcp-project
GCP_REGION=""                 # e.g. us-central1
GCP_ACCESS_TOKEN=""           # managed by `solomog gcp:refresh` (leave blank initially)

# AWS / Bedrock. The three AWS_* values are SHORT-LIVED SSO credentials — do NOT paste them
# by hand; run `solomog aws:refresh` to (re)fetch them into .env, then re-run your bundle.
# AWS_PROFILE selects which configured SSO profile aws:refresh exports (set it once after
# `aws configure sso`). AWS_SSO_SESSION names the SSO session for the login fallback (SOlo).
AWS_PROFILE=""                # e.g. solo-sso  (the profile `aws configure sso` created)
AWS_SSO_SESSION=""            # SSO session name (default: SOlo) — only used for sso-login
AWS_ACCESS_KEY_ID=""          # managed by `solomog aws:refresh` (leave blank initially)
AWS_SECRET_ACCESS_KEY=""      # managed by `solomog aws:refresh` (leave blank initially)
AWS_SESSION_TOKEN=""          # managed by `solomog aws:refresh` (leave blank initially)

# ─── OBO token exchange (enterprise agentgateway STS) ────────────────────────
# TOKEN_EXCHANGE itself is CLI-ONLY — deliberately NOT settable here. It's a global,
# repo-wide dotenv value, not per-cluster, so persisting it would silently try to enable
# the STS on the NEXT agentgateway install on ANY cluster (even an unrelated one without
# Keycloak), crash-looping the controller. Pass it explicitly on the command that needs it:
#   solomog agentgateway CLUSTER=<cluster> TOKEN_EXCHANGE=true
# The two settings below ARE safe to persist — they're inert unless TOKEN_EXCHANGE=true is
# also passed on that same command.
# JWKS_URL is the IdP whose user tokens the STS validates (default: the in-cluster Keycloak
# from the OBO scenario). API_VALIDATOR=k8s suits the basic curl-driven OBO flow; set it to
# `remote` (validated against the same JWKS) if you want the Solo UI's elicitation API to work.
TOKEN_EXCHANGE_JWKS_URL=""            # default: http://keycloak.keycloak.svc.cluster.local:8080/realms/obo-realm/protocol/openid-connect/certs
TOKEN_EXCHANGE_API_VALIDATOR=""       # k8s (default) | remote — use remote for Solo UI elicitation
