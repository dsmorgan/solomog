#!/usr/bin/env bash
# solomog — thin wrapper around task that always runs from the solomog repo root.
# Symlink this to ~/.local/bin/solomog (done by: bash scripts/setup.sh).
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
cd "$SCRIPT_DIR"

if ! command -v task &>/dev/null; then
  echo "solomog: 'task' (go-task) is not installed yet." >&2
  echo "Bootstrap prerequisites first:  bash \"$SCRIPT_DIR/scripts/setup.sh\"" >&2
  exit 127
fi

# 🗿 mog bookends + per-task timing. The wrapper runs each requested task in turn,
# times it, and prints ONE summary at the end listing each task's run time plus the
# grand total — so a chained run (`solomog a b c`) shows a clean per-task breakdown
# instead of scattered mini-summaries. Per-task progress framing (step delimiters)
# still lives in the scripts.
source "$SCRIPT_DIR/scripts/lib/ui.sh"

# Audit log: one compact line per run, in a monthly-rotated file beside the test runs
# (.solomog/audit/YYYY-MM.log — gitignored). Records timestamp, ok/FAIL, exit code, total
# time, and the command with secret-looking var VALUES redacted. Best-effort: never fails
# the run. Populated from TASKS/VARS/AUDIT_TASKS/SECONDS set below.
AUDIT_TASKS=()
_solomog_audit() {
  local rc="$1" status dir month v name cmd line red=()
  [ "$rc" = "0" ] && status=ok || status=FAIL
  dir="$SCRIPT_DIR/.solomog/audit"
  month="$(date +%Y-%m 2>/dev/null)" || return 0
  mkdir -p "$dir" 2>/dev/null || return 0
  for v in "${VARS[@]}"; do
    name="${v%%=*}"
    case "$(printf '%s' "$name" | tr '[:lower:]' '[:upper:]')" in
      *KEY*|*TOKEN*|*SECRET*|*PASSWORD*|*PASS*) red+=("${name}=***") ;;
      *) red+=("$v") ;;
    esac
  done
  cmd="$(printf '%s ' "${TASKS[@]}" "${red[@]}")"; cmd="${cmd% }"
  line="$(date +%Y-%m-%dT%H:%M:%S%z)  ${status}  rc=${rc}  dur=${SECONDS}s  ${cmd}"
  [ "${#AUDIT_TASKS[@]}" -gt 1 ] && line="${line}  [${AUDIT_TASKS[*]}]"
  printf '%s\n' "$line" >> "$dir/${month}.log" 2>/dev/null || true
}

# Bare `solomog` (no args) → just the task list, no framing (not audited).
if [ $# -eq 0 ]; then
  exec task
fi

# `solomog help [task...]` → detailed per-task help (variables/options + examples),
# via go-task's --summary. Meta command: no mog framing, not audited. With no task it
# points at the full list. Tasks without a summary fall back to their one-line desc.
if [ "$1" = "help" ] || [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
  shift
  if [ $# -eq 0 ]; then
    echo "Detailed task help:  solomog help <task>   (e.g. solomog help expose)"
    echo "Full task list:      solomog"
    exit 0
  fi
  # `task --summary` appends the task's resolved `vars:`/`env:` blocks — which include
  # .env SECRET VALUES (license keys, tokens). Strip that trailer so help never leaks
  # credentials; keep only the summary prose. Our summaries use "Variables:" (capital,
  # plural), never a bare "vars:"/"env:" line, so this can't clip real help content.
  task --summary "$@" 2>&1 | awk '
    /^(vars|env):/ { skip=1; next }
    /^task:/       { skip=0; print; next }
    !skip          { print }'
  exit ${PIPESTATUS[0]}
fi

# Pick removal-themed banter when a teardown is in the run.
MOG_MODE=""
for arg in "$@"; do
  case "$arg" in
    teardown|teardown:*) MOG_MODE=destroy; break ;;
  esac
done

# Split args into task names and KEY=VALUE globals. The globals apply to every task;
# task names use ':' not '=', so '=' is a safe delimiter to partition on.
TASKS=(); VARS=()
for a in "$@"; do
  case "$a" in
    *=*) VARS+=("$a") ;;
    *)   TASKS+=("$a") ;;
  esac
done

solomog_intro "$MOG_MODE"
solomog_clock_reset   # grand-total clock (this process; task subprocesses don't touch it)

# Only globals, no task names → defer to task unchanged (e.g. it picks the default).
if [ ${#TASKS[@]} -eq 0 ]; then
  task "$@"; rc=$?
  _solomog_audit "$rc"
  solomog_outro "$rc" "$MOG_MODE"
  exit $rc
fi

rc=0
TASK_TIMES=()
for t in "${TASKS[@]}"; do
  t_start=$SECONDS
  if [ ${#VARS[@]} -gt 0 ]; then task "$t" "${VARS[@]}"; else task "$t"; fi
  trc=$?
  t_dur=$((SECONDS - t_start))
  if [ "$trc" -eq 0 ]; then
    TASK_TIMES+=("$t  —  ${t_dur}s")
    AUDIT_TASKS+=("${t}=${t_dur}s")
  else
    TASK_TIMES+=("$t  —  ${t_dur}s  (FAILED, exit $trc)")
    AUDIT_TASKS+=("${t}=${t_dur}s(rc${trc})")
    rc=$trc
    break   # stop the chain on first failure
  fi
done

solomog_summary "Run complete — ${#TASK_TIMES[@]} task(s)" "${TASK_TIMES[@]}"
_solomog_audit "$rc"
solomog_outro "$rc" "$MOG_MODE"
exit $rc
