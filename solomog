#!/usr/bin/env bash
# solomog — thin wrapper around task that always runs from the solomog repo root.
# Symlink this to ~/.local/bin/solomog (done by: bash scripts/setup.sh).
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
cd "$SCRIPT_DIR"

if ! command -v task &>/dev/null; then
  echo "solomog: 'task' (go-task) is not installed yet." >&2
  echo "Bootstrap prerequisites first:  bash \"$SCRIPT_DIR/scripts/setup.sh\"" >&2
  exit 127
fi

# 🗿 mog bookends: one opening message before the run, one closing message after —
# regardless of how many tasks are chained. Per-task framing lives in the scripts.
# Skipped for a bare `solomog` (no args = just the task list).
source "$SCRIPT_DIR/scripts/lib/ui.sh"

# Pick removal-themed banter when a teardown is in the run, so the bookends talk
# about deleting things rather than spinning them up.
MOG_MODE=""
for arg in "$@"; do
  case "$arg" in
    teardown|teardown:*) MOG_MODE=destroy; break ;;
  esac
done

[ $# -gt 0 ] && solomog_intro "$MOG_MODE"

task "$@"
rc=$?

[ $# -gt 0 ] && solomog_outro "$rc" "$MOG_MODE"
exit $rc
