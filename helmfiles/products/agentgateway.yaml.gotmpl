# Product module: agentgateway.
#
#   enterprise → enterprise-agentgateway-crds + enterprise-agentgateway (CalVer default)
#                repo oci://us-docker.pkg.dev/solo-public/enterprise-agentgateway/charts
#                license licensing.licenseKey.
#                Verified: https://docs.solo.io/agentgateway/2.3.x/install/helm/
#   community  → agentgateway-crds + agentgateway (OSS line; see AGENTGATEWAY_COMMUNITY_VERSION)
#                repo oci://cr.agentgateway.dev/charts
#                Verified: https://agentgateway.dev/docs/kubernetes/latest/install/helm/
#
# Both editions install to agentgateway-system and require the Kubernetes Gateway
# API CRDs (applied first via a presync hook).
#
# License: agentgateway_license_key (AGENTGATEWAY_LICENSE_KEY or SOLO_LICENSE_KEY).
# Composed via: solomog stack CLUSTER=... PRODUCTS="agentgateway"

bases:
  - ../commons.yaml

---

repositories:
  - name: agentgateway
    url: "{{ .Values.helm_repo_agentgateway }}"
    oci: true

releases:
  - name: agentgateway-crds
    namespace: agentgateway-system
    chart: agentgateway/{{ if eq .Environment.Name "enterprise" }}enterprise-agentgateway-crds{{ else }}agentgateway-crds{{ end }}
    version: "{{ .Values.agentgateway_version }}"
    wait: true
    hooks:
      - events: ["presync"]
        showlogs: true
        command: kubectl
        args:
          - "--context={{ env "SOLO_CONTEXT" | default "vcluster-docker_cluster-one" }}"
          - apply
          - --server-side
          - -f
          - "https://github.com/kubernetes-sigs/gateway-api/releases/download/v{{ .Values.gateway_api_version }}/standard-install.yaml"

  - name: agentgateway
    namespace: agentgateway-system
    chart: agentgateway/{{ if eq .Environment.Name "enterprise" }}enterprise-agentgateway{{ else }}agentgateway{{ end }}
    version: "{{ .Values.agentgateway_version }}"
    wait: true
    needs:
      - agentgateway-system/agentgateway-crds
    values:
      - ../../values/agentgateway/values.yaml
{{ if eq .Environment.Name "enterprise" }}
      - licensing:
          licenseKey: "{{ .Values.agentgateway_license_key }}"
{{ end }}
{{- /* OBO token-exchange STS (enterprise-only). Opt-in via TOKEN_EXCHANGE=true; off otherwise
       so the normal install is untouched. Shape follows the 2.3.x OBO docs. The chart passes
       this whole block to the controller as JSON (KGW_AGENTGATEWAY_TOKEN_EXCHANGE_CONFIG) and
       gates the :7777 STS port on `enabled`. JWKS URL defaults to the in-cluster Keycloak; set
       TOKEN_EXCHANGE_JWKS_URL for another IdP. apiValidator defaults to k8s (basic OBO); set
       TOKEN_EXCHANGE_API_VALIDATOR=remote when you want the Solo UI's elicitation API to work
       (k8s rejects the UI's Keycloak JWTs with 401). */ -}}
{{- if and (eq .Environment.Name "enterprise") (eq (env "TOKEN_EXCHANGE") "true") }}
{{- $jwks := env "TOKEN_EXCHANGE_JWKS_URL" | default "http://keycloak.keycloak.svc.cluster.local:8080/realms/obo-realm/protocol/openid-connect/certs" }}
      - tokenExchange:
          enabled: true
          issuer: "enterprise-agentgateway.agentgateway-system.svc.cluster.local:7777"
          tokenExpiration: 24h
          subjectValidator:
            validatorType: remote
            remoteConfig:
              url: "{{ $jwks }}"
          actorValidator:
            validatorType: k8s
          # apiValidator validates the SOLO UI's calls into the STS elicitation CRUD API. Per the
          # Solo elicitation docs, this must be the SAME IdP JWKS as subjectValidator: once the UI
          # is wired to the IdP (see agentgateway-ui.yaml.gotmpl OIDC block), the UI signs its STS
          # calls with IdP-issued (e.g. Okta) tokens, so it validates against the IdP JWKS — NOT
          # the UI's dev-autoauth keys (:5556/keys), which only apply while the UI runs in autoauth
          # mode and is the reason elicited tokens landed under the wrong identity. Defaults to the
          # IdP JWKS ($jwks); override with TOKEN_EXCHANGE_API_VALIDATOR_URL only if it differs.
          apiValidator:
{{- /* eager-auth (OAUTH_ISSUER=true) matches the lab and defaults apiValidator to remote→IdP JWKS;
       otherwise k8s. Always overridable via TOKEN_EXCHANGE_API_VALIDATOR. */ -}}
{{- if eq (env "TOKEN_EXCHANGE_API_VALIDATOR" | default (ternary "remote" "k8s" (eq (env "OAUTH_ISSUER") "true"))) "remote" }}
            validatorType: remote
            remoteConfig:
              url: "{{ env "TOKEN_EXCHANGE_API_VALIDATOR_URL" | default $jwks }}"
{{- else }}
            validatorType: k8s
{{- end }}
{{- /* Elicitation (browser-consent OAuth to a SaaS, e.g. Snowflake). The STS needs a GLOBAL
       fallback OAuth-provider secret (chart: tokenExchange.elicitation.secretName — "Required
       unless mode is ExchangeOnly") even though the per-backend policy also names one; without
       it the data plane returns "token exchange required but not configured". CALLBACK_URL is
       the UI URL the browser returns to after consent — must match the secret's redirect_uri
       AND the SaaS OAuth app's registered redirect. Both are inert unless TOKEN_EXCHANGE=true. */ -}}
{{- if env "TOKEN_EXCHANGE_ELICITATION_SECRET" }}
          elicitation:
            secretName: "{{ env "TOKEN_EXCHANGE_ELICITATION_SECRET" }}"
{{- end }}
{{- if env "TOKEN_EXCHANGE_CALLBACK_URL" }}
      - controller:
          extraEnv:
            CALLBACK_URL: "{{ env "TOKEN_EXCHANGE_CALLBACK_URL" }}"
{{- end }}
{{- /* Eager-auth OAuth issuer (opt-in via OAUTH_ISSUER=true; requires TOKEN_EXCHANGE=true, so it
       lives inside that guard). The controller becomes the OAuth Authorization Server MCP clients
       see (@ /oauth-issuer): it serves its own AS metadata, does "fake DCR" returning a
       pre-registered Okta client_id, and brokers the auth-code flow to Okta. Without this env the
       controller logs "KGW_OAUTH_ISSUER_CONFIG is not set, OAuth issuer handler will not be
       registered" and discovery/DCR elicitation (e.g. Atlassian) can't build a consent URL.
       State store: no tokenExchange.database block above → SQLite in-memory (fine for a PoV; state
       is lost on controller restart → re-consent). Add a database block for Postgres-backed state.
       Host + Okta creds come from .env via the bundle's run command (OAUTH_ISSUER_HOST defaults to
       agw.<cluster>.test in the Taskfile). Ref: workshop labs/mcp/mcp-eager-auth-okta.md Step 5. */ -}}
{{- if eq (env "OAUTH_ISSUER") "true" }}
{{- $issuer := printf "https://%s/oauth2/%s" (env "OKTA_DOMAIN") (env "OKTA_AUTH_SERVER_ID" | default "default") }}
{{- $host := env "OAUTH_ISSUER_HOST" }}
{{- /* eager-auth client = a CONFIDENTIAL Authorization Code Okta app with the two
       /oauth-issuer/callback/{downstream,upstream} redirect URIs. This is NOT the API-Services
       (client-credentials) app OKTA_CLIENT_ID points at for the agw-okta-mcp tests. Use a dedicated
       OAUTH_ISSUER_CLIENT_ID/SECRET (e.g. your Solo UI backend confidential app); falls back to
       OKTA_CLIENT_ID/SECRET only for the simple single-app case. */ -}}
{{- $cid := env "OAUTH_ISSUER_CLIENT_ID" | default (env "OKTA_CLIENT_ID") }}
{{- $csec := env "OAUTH_ISSUER_CLIENT_SECRET" | default (env "OKTA_CLIENT_SECRET") }}
      - controller:
          extraEnv:
            # The exact env var name the controller reads. JSON string; client_secret comes from
            # .env (OKTA_CLIENT_SECRET) so nothing sensitive is committed.
            KGW_OAUTH_ISSUER_CONFIG: |
              {
                "gateway_config": { "base_url": "https://{{ $host }}/oauth-issuer" },
                "client_config": { "clients": { "{{ $cid }}": "{{ $csec }}" } },
                "downstream_server": {
                  "name": "okta",
                  "client_id": "{{ $cid }}",
                  "client_secret": "{{ $csec }}",
                  "authorize_url": "{{ $issuer }}/v1/authorize",
                  "token_url": "{{ $issuer }}/v1/token",
                  "redirect_uri": "https://{{ $host }}/oauth-issuer/callback/downstream",
                  "scopes": ["openid", "profile", "email"]
                }
              }
{{- end }}
{{- end }}
