# Add-on: Solo UI / management plane for agentgateway (the `management` chart).
#
# This is the UI half of the `solomog agentgateway:ui` scenario. The Solo UI is a
# single `management` chart with per-product toggles — here we enable only the
# agentgateway product, so the same chart can later serve other products' UIs
# (e.g. mesh) via their own <product>:ui add-ons.
#
#   ENTERPRISE ONLY. The Solo UI is an enterprise feature; there is no community
#   equivalent. The install script guards EDITION=community before reaching here.
#
# CRDs: the `management-crds` subchart is bundled inside `management` and enabled
# by default — we let the chart own them (the official 2.3.x install path). The
# workshop's separate management-crds release + `enabled=false` is the Helm CRD-
# lifecycle pattern for long-lived mgmt clusters; it buys nothing for ephemeral
# vclusters, so we skip it.
#
# License: agentgateway_license_key (AGENTGATEWAY_LICENSE_KEY or SOLO_LICENSE_KEY).
# Tracing wiring (EnterpriseAgentgatewayPolicy) is applied by install-agentgateway-ui.sh
# after this sync, since it targets the Gateway created by `solomog expose`.
#
# Verified: https://docs.solo.io/agentgateway/2.3.x/install/ui/setup/

bases:
  - ../commons.yaml

---

repositories:
  - name: solo-enterprise
    url: "{{ .Values.helm_repo_solo_enterprise }}"
    oci: true

releases:
  - name: management
    namespace: agentgateway-system
    chart: solo-enterprise/management
    version: "{{ .Values.agw_ui_version }}"
    wait: true
    values:
      - cluster: "{{ env "SOLO_CLUSTER" | default "mgmt-cluster" }}"
        licensing:
          licenseKey: "{{ .Values.agentgateway_license_key }}"
        global:
          imagePullPolicy: IfNotPresent
        service:
          type: ClusterIP
        products:
          # Enable only the agentgateway UI. Other products get their own <product>:ui.
          agentgateway:
            enabled: true
            namespace: agentgateway-system
          kagent:
            enabled: false
          mesh:
            enabled: false
          agentregistry:
            enabled: false
        clickhouse:
          enabled: true
        tracing:
          verbose: true
{{- /* OIDC: wire the UI to a real IdP (e.g. Okta) instead of the bundled dev "autoauth" IdP
       (image solo-enterprise-autoauth). Opt-in — the block renders ONLY when SOLO_UI_OIDC_ISSUER
       is set, so the default install stays in autoauth mode, untouched. The chart has no explicit
       autoauth on/off toggle; setting oidc.issuer is what switches it to real OIDC.
       WHY THIS MATTERS FOR ELICITATION: browser-consent (elicitation) stores the SaaS token keyed
       by the user's `sub`. If the UI logs the user in via autoauth, that sub != the Okta sub on the
       MCP-request JWT, so the elicited token is never found on replay. The UI must authenticate the
       user as the SAME IdP identity as the MCP route — hence issuer = the same Okta default AS as
       the route JWT + the STS apiValidator (see products/agentgateway.yaml.gotmpl). Two Okta apps:
       a confidential Web app (backend) and a public SPA (frontend) — see bundles/agw-okta-mcp/OKTA-SETUP.md.
       Client secret comes from .env (SOLO_UI_OIDC_BACKEND_CLIENT_SECRET), injected inline like the
       license key — never committed. */ -}}
{{- if env "SOLO_UI_OIDC_ISSUER" }}
        oidc:
          issuer: "{{ env "SOLO_UI_OIDC_ISSUER" }}"
          additionalScopes: {{ env "SOLO_UI_OIDC_ADDITIONAL_SCOPES" | default "[\"profile\",\"email\"]" }}
        rbac:
          roleMapping:
            # PoV default: grant every authenticated user global.Admin (a bare CEL list literal, so
            # it ignores claims). For group-based roles instead, add a Groups claim in Okta + set
            # SOLO_UI_OIDC_ROLE_MAPPER to the chart default "claims.Groups.transformList(...)".
            roleMapper: '{{ env "SOLO_UI_OIDC_ROLE_MAPPER" | default "[\"global.Admin\"]" }}'
        ui:
          backend:
            oidc:
              clientId: "{{ env "SOLO_UI_OIDC_BACKEND_CLIENT_ID" }}"
              # Inline secret from .env → the chart CREATES a Secret named `secretRef`
              # (its default `ui-backend-oidc-secret`) holding it, and the ui-backend mounts
              # that name. Do NOT set secretRef:"" — it's the mount NAME, not a toggle; empty
              # makes the chart create/mount a Secret named "" (resource name may not be empty).
              secret: "{{ env "SOLO_UI_OIDC_BACKEND_CLIENT_SECRET" }}"
              secretKey: clientSecret
          frontend:
            oidc:
              clientId: "{{ env "SOLO_UI_OIDC_FRONTEND_CLIENT_ID" }}"
{{- end }}
