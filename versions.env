# Pinned product versions. Run `solomog versions:update` to fetch latest from GitHub.

# Gloo Mesh Enterprise management plane (optional product; repo unverified).
GLOO_MESH_VERSION=2.6.5

# Gloo Operator — installs Solo's managed Istio (enterprise istio path).
GLOO_OPERATOR_VERSION=0.5.2

# kgateway. Enterprise (kgateway 2.2.x) and community/OSS (2.3.x) are on
# different version lines and registries; community.yaml uses the _COMMUNITY_ value.
KGATEWAY_VERSION=2.2.0
KGATEWAY_COMMUNITY_VERSION=v2.3.1

# Gloo Gateway (separate product from kgateway).
GLOO_GATEWAY_VERSION=1.21.6

# agentgateway. Enterprise (2.3.x) and community/OSS (1.3.x) differ; chart
# versions use a "v" prefix. community.yaml uses the _COMMUNITY_ value.
AGENTGATEWAY_VERSION=v2.3.3
AGENTGATEWAY_COMMUNITY_VERSION=v1.3.0

# Istio version. For enterprise this is the version the Gloo Operator manages
# (Solo supports n-1); the operator pulls the matching "-solo" image tag.
# For EDITION=community this must be a valid upstream istio-release chart version
# (e.g. 1.26.x for ambient) — adjust when running community.
ISTIO_VERSION=1.30.1

# Gateway API CRDs (installed on each cluster by the product modules' presync hooks).
GATEWAY_API_VERSION=1.5.1

# Per-cluster Istio version overrides (uncomment to enable mixed-version scenarios).
# Useful for testing upgrades or reproducing version-specific customer issues.
# ISTIO_VERSION_CLUSTER_TWO=1.29.2
# ISTIO_VERSION_CLUSTER_THREE=1.28.3
