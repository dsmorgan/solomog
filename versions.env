# Pinned product versions. Run `solomog versions:update` for a read-only check
# against GitHub latest (it never writes this file — bump pins by hand).

# Gloo Mesh Enterprise management plane (optional product; repo unverified).
GLOO_MESH_VERSION=2.6.5

# Gloo Operator — installs Solo's managed Istio (enterprise istio path).
GLOO_OPERATOR_VERSION=0.5.2

# kgateway. Enterprise (kgateway 2.2.x) and community/OSS (2.3.x) are on
# different version lines and registries; community.yaml uses the _COMMUNITY_ value.
KGATEWAY_VERSION=2.2.0
KGATEWAY_COMMUNITY_VERSION=v2.3.1

# Gloo Gateway (separate product from kgateway).
GLOO_GATEWAY_VERSION=1.21.6

# agentgateway. Enterprise and community/OSS differ; chart versions use a "v" prefix.
# community.yaml uses the _COMMUNITY_ value.
#
# Solo is mid-transition SemVer → CalVer (YYYY.MM.micro). CalVer is the direction of
# travel for several Solo products starting with agentgateway — it is a naming scheme,
# NOT an LTS / "latest" / "unstable" channel indicator by itself. Supported channels
# (support window, production recommendation, etc.) are documented separately by Solo;
# do not read "CalVer vs SemVer" as "dev vs stable".
#   Ref: https://docs.solo.io/agentgateway/2.3.x/reference/versions/#supported-versions
#
# CURRENT DEFAULT = v2026.6.3 (CalVer): the active MCP identity PoV (bundles/agw-okta-mcp,
# agw-atlassian-mcp — elicitation/token-exchange, eager-auth issuer) targets this feature
# set. For scenarios that must mirror a customer env on the older SemVer line, override:
# AGENTGATEWAY_VERSION=v2.3.3.
#   Side effect: the EnterpriseAgentgatewayBackend CRD relaxed its CEL rules on the CalVer
#   line (a `policies` block may contain just `auth`). On 2.3.x the stricter rule applies —
#   `policies` must also carry a non-empty `policies.ai`. So on 2.3.x, Solo workshop
#   manifests written for CalVer need a `policies.ai` block added to validate.
AGENTGATEWAY_VERSION=v2.3.3   # LTS
# AGENTGATEWAY_VERSION=v2026.6.3
AGENTGATEWAY_COMMUNITY_VERSION=v1.3.0

# Istio version. For enterprise this is the version the Gloo Operator manages
# (Solo supports n-1); the operator pulls the matching "-solo" image tag.
# For EDITION=community this must be a valid upstream istio-release chart version
# (e.g. 1.26.x for ambient) — adjust when running community.
ISTIO_VERSION=1.30.1

# Gateway API CRDs (installed on each cluster by the product modules' presync hooks).
GATEWAY_API_VERSION=1.5.1

# ─── Add-ons — MANUALLY PINNED ──────────────────────────────────────────────
# NOTE: `solomog versions:update` does NOT check the two below (and never writes
# this file). They are not tracked as GitHub releases (the `management` chart and
# kube-prometheus-stack live in Helm/OCI registries). Update these by hand.

# Solo UI / management plane (the `management` chart — used by <product>:ui add-ons).
# Bundles its CRDs as a subchart (enabled by default), so no separate management-crds
# install is needed. Verified: https://docs.solo.io/agentgateway/2.3.x/install/ui/setup/
AGW_UI_VERSION=0.4.8

# Monitoring add-on: kube-prometheus-stack (Prometheus + Grafana), from the
# prometheus-community Helm repo. Verified against workshop 002 (UI + monitoring).
KUBE_PROM_STACK_VERSION=80.4.2

# Per-cluster Istio version overrides (uncomment to enable mixed-version scenarios).
# Useful for testing upgrades or reproducing version-specific customer issues.
# ISTIO_VERSION_CLUSTER_TWO=1.29.2
# ISTIO_VERSION_CLUSTER_THREE=1.28.3
